{
  "name": "kreaklone-mvp-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node apps/server/src/server.js",
    "dev:web-v2": "npm run dev --prefix apps/web-v2",
    "dev:preview-worker": "node preview-worker/index.js",
    "dev:refine-worker": "node refine-worker/index.js",
    "dev:upscale-worker": "node upscale-worker/index.js",
    "build:web-v2": "npm run build --prefix apps/web-v2",
    "preview:web-v2": "npm run preview --prefix apps/web-v2",
    "serve:web-v2": "WEB_APP_VARIANT=v2 node apps/server/src/server.js",
    "lint": "node scripts/lint.js",
    "typecheck": "node scripts/typecheck.js",
    "static-analysis": "node scripts/static-analysis.js",
    "test": "node --test tests/*.test.js",
    "benchmarks:catalog": "node scripts/print-benchmark-catalog.js",
    "verify": "npm run lint && npm run typecheck && npm run static-analysis && npm test"
  }
}
